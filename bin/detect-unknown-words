#!/usr/bin/env python3

# Synopsis:
# Report words that an exercise's reference solution uses but that
# haven't been taught yet -- either in the exercise's own
# .docs/introduction.md (concept exercise) or in any transitive
# prereq's introduction (concept and practice exercises).
#
# Reads the per-exercise .meta/known-words.md files written by
# bin/extract-known-words. Each known-words.md lists only the words
# from that exercise's own introduction; this script walks the prereq
# graph to build the transitive set. Run extract-known-words first
# whenever introductions change.
#
# Usage:
#   bin/detect-unknown-words              # both concept and practice
#   bin/detect-unknown-words concept      # only concept exercises
#   bin/detect-unknown-words practice     # only practice exercises

import re, sys, json
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
CFG = json.loads((ROOT / 'config.json').read_text())

SYNTAX = set("[ ] { } ( ) [| | ; T{ H{ V{ B{".split())
SYNTAX |= set("USING: IN: CONSTANT: SYMBOL: SYMBOLS: TUPLE: ERROR: PREDICATE: FROM: BUILTIN: HOOK: DEFER:".split())
SYNTAX |= set("PRIVATE> <PRIVATE QUALIFIED:".split())
# Parser/protocol words from `make` blocks. `,` and `%` only have meaning
# inside `[ ... ] make` and aren't called as ordinary Factor words.
SYNTAX |= set(", %".split())
PRIMITIVES = set(":: : ; -- :>".split())


# Map: concept slug -> exercise slug that teaches it (concept exercises only)
CONCEPT_TO_EX = {}
EX_META = {ex['slug']: ex for ex in CFG['exercises']['concept']}
for ex in CFG['exercises']['concept']:
    for c in ex['concepts']:
        CONCEPT_TO_EX[c] = ex['slug']


def known_words_for_concept_ex(slug):
    """Read the concept exercise's known-words.md and return the word set."""
    p = ROOT / 'exercises' / 'concept' / slug / '.meta' / 'known-words.md'
    if not p.exists():
        return set()
    return {m.group(1) for m in re.finditer(r'^- `([^`]+)`', p.read_text(), re.M)}


def transitive_prereq_concept_exes(prereq_concepts):
    """Walk the concept-prereq graph; return concept-exercise slugs."""
    seen = set()
    queue = list(prereq_concepts)
    while queue:
        c = queue.pop(0)
        if c in CONCEPT_TO_EX:
            ex = CONCEPT_TO_EX[c]
            if ex not in seen:
                seen.add(ex)
                queue.extend(EX_META[ex]['prerequisites'])
    return seen


def _add_local(locals_, tok):
    """Register a token from a locals-bearing parameter list."""
    if tok.startswith('('):
        return
    # `name:` declares an inline-effect local (e.g. `quot: ( x -- y )`);
    # strip the trailing colon and register the bare name.
    if tok.endswith(':'):
        locals_.add(tok[:-1])
        return
    locals_.add(tok)
    # Mutable variant: a! is the setter for local a, but the local itself is a.
    if tok.endswith('!'):
        locals_.add(tok[:-1])


def parse_solution(paths):
    """Return (defined, locals, used, text) parsed across one or more files.

    `paths` may be a single Path or a list — multi-file exercises pass
    every solution file so a word defined in one file is visible in
    another."""
    if isinstance(paths, Path):
        paths = [paths]
    text = '\n'.join(p.read_text() for p in paths if p.exists())
    defined, locals_ = set(), set()

    # Top-level word definitions: `:` and `::`.
    for m in re.finditer(r'^::?\s+(\S+)\s*\(', text, re.M):
        defined.add(m.group(1))
    # Locals-bearing definitions:
    #   `:: <word> ( ... -- ... )`
    #   `M:: <class> <word> ( ... -- ... )`
    # The names aren't "defined" by `M::` (the generic was declared
    # elsewhere), but the parameter list does introduce locals.
    for m in re.finditer(
        r'^(?:::\s+\S+|M::\s+\S+\s+\S+)\s*\(([^)]*)--[^)]*\)',
        text, re.M,
    ):
        for tok in m.group(1).split():
            _add_local(locals_, tok)
    # Locals lambda [| a b | ... ]
    for m in re.finditer(r'\[\|\s*([^|]+?)\|', text):
        for tok in m.group(1).split():
            _add_local(locals_, tok)
    # `:> ( a b c )` or `:> { a b c }` introduces multiple locals
    for m in re.finditer(r':>\s+[({]([^)}]+)[)}]', text):
        for tok in m.group(1).split():
            _add_local(locals_, tok)
    # `:> name` or `:> name!` introduces a single local
    for m in re.finditer(r':>\s+(\S+)', text):
        n = m.group(1)
        if n.startswith('{') or n.startswith('('):
            continue
        _add_local(locals_, n)

    for m in re.finditer(r'^\s*CONSTANT:\s+(\S+)', text, re.M):
        defined.add(m.group(1))
    for m in re.finditer(r'^\s*SYMBOL:\s+(\S+)', text, re.M):
        defined.add(m.group(1))
    for m in re.finditer(r'^\s*SYMBOLS:\s+([^;]+);', text, re.M):
        defined.update(m.group(1).split())
    for m in re.finditer(r'^\s*DEFER:\s+(\S+)', text, re.M):
        defined.add(m.group(1))
    # GENERIC:/GENERIC#:/HOOK: declare a new word; the body of the
    # method on each class lives in `M:`/`M::` and doesn't redeclare.
    for m in re.finditer(r'^\s*(?:GENERIC|GENERIC#|HOOK):\s+(\S+)', text, re.M):
        defined.add(m.group(1))
    for m in re.finditer(r'^\s*TUPLE:\s+(\S+)\s*([^;]*);?', text, re.M):
        cls = m.group(1)
        # Tuple definitions auto-generate the class name and a `<class>?`
        # predicate. Slot accessors come below.
        defined.update([cls, f'{cls}?'])
        sig = m.group(2)
        # Strip optional `< parent` so we don't mis-treat `<` and the
        # parent name as slots.
        sig = re.sub(r'^\s*<\s*\S+', '', sig, count=1)
        for sb in re.finditer(r'\{\s*(\S+)[^}]*\}', sig):
            slot = sb.group(1)
            defined.update([slot, f'{slot}>>', f'>>{slot}', f'change-{slot}'])
        depth = 0
        for tok in sig.split():
            if tok == '{':
                depth += 1; continue
            if tok == '}':
                depth -= 1; continue
            if depth == 0:
                defined.update([tok, f'{tok}>>', f'>>{tok}', f'change-{tok}'])
    for m in re.finditer(r'^\s*ERROR:\s+(\S+)\s*([^;]*);?', text, re.M):
        cls = m.group(1)
        # Same auto-generated predicate as TUPLE:.
        defined.update([cls, f'{cls}?'])
        for tok in m.group(2).split():
            defined.update([tok, f'{tok}>>', f'>>{tok}', f'change-{tok}'])

    # USING: vocabulary names — multi-line aware
    imports = set()
    for m in re.finditer(r'USING:\s+(.*?);', text, re.S):
        imports.update(m.group(1).split())

    body = re.sub(r'\(\s*(?:[^()]|\([^)]*\))*\s*\)', '', text)
    body = re.sub(r'!\s.*', '', body)
    body = re.sub(r'"[^"\n]*"', '', body)
    body = re.sub(r'CHAR:\s+\S+', '', body)
    body = re.sub(r'^\s*USING:.*?;', '', body, flags=re.M | re.S)
    body = re.sub(r'^\s*IN:.*$', '', body, flags=re.M)
    # Declarative headers — slot/error metadata are not code.
    body = re.sub(r'^\s*(?:TUPLE|ERROR):.*?;', '', body, flags=re.M | re.S)
    body = re.sub(r'^\s*(?:SYMBOL|CONSTANT|DEFER):.*$', '', body, flags=re.M)
    body = re.sub(r'^\s*SYMBOLS:.*?;', '', body, flags=re.M | re.S)
    body = re.sub(r'^\s*INSTANCE:.*$', '', body, flags=re.M)
    body = re.sub(r'^\s*(?:GENERIC|GENERIC#|HOOK):.*$', '', body, flags=re.M)
    body = re.sub(r'\[\|[^|]*\|', '', body)

    used = set()
    for tok in body.split():
        if not tok:
            continue
        if tok in defined or tok in locals_:
            continue
        if tok in SYNTAX or tok in PRIMITIVES:
            continue
        if re.fullmatch(r"-?\d[\d_]*(\.\d+)?(/-?\d+)?(e-?\d+)?", tok):
            continue
        if re.fullmatch(r'0x[0-9a-fA-F]+|0b[01]+', tok):
            continue
        if tok in imports:
            continue
        if re.fullmatch(r'[()\[\]{}|;]+', tok):
            continue
        used.add(tok)
    return defined, locals_, used, text


# Syntactic features that don't tokenise as ordinary words but still
# require a concept be in the prereq chain. The detector filters these
# tokens (so they never appear in the per-word "unknown" list), so we
# need an explicit presence check.
LOCALS_SYNTAX = re.compile(r'(?:^|\s)(?:::|:>|\[\|)(?:\s|$)')


def reachable_concepts(prereqs):
    """Return the set of concept slugs reachable through the prereq chain."""
    concepts = set()
    for ex_slug in transitive_prereq_concept_exes(prereqs):
        concepts.update(EX_META[ex_slug].get('concepts', []))
    return concepts


def syntax_violations(text, reachable):
    """Return concept slugs whose syntactic features appear in the source
    but whose teaching exercise is not reachable through the prereq chain."""
    violations = []
    if LOCALS_SYNTAX.search(text) and 'locals' not in reachable:
        violations.append('<missing locals prereq>')
    return violations


def solution_files(exercise_dir, kind):
    """Return all solution files for an exercise per its .meta/config.json."""
    cfg = json.loads((exercise_dir / '.meta' / 'config.json').read_text())
    key = 'exemplar' if kind == 'concept' else 'example'
    return [exercise_dir / f for f in cfg.get('files', {}).get(key, [])]


def check_concept(slug, exercise_dir):
    """Concept exercise: known = its own intro plus the intros of every
    transitive prereq concept-exercise."""
    known = known_words_for_concept_ex(slug)
    for cx in transitive_prereq_concept_exes(EX_META[slug].get('prerequisites', [])):
        known |= known_words_for_concept_ex(cx)
    defined, locals_, used, text = parse_solution(solution_files(exercise_dir, 'concept'))
    unknowns = sorted(used - known - defined - locals_)
    own_concepts = set(EX_META[slug].get('concepts', []))
    reachable = own_concepts | reachable_concepts(EX_META[slug].get('prerequisites', []))
    return unknowns + syntax_violations(text, reachable)


def check_practice(prereqs, exercise_dir):
    """Practice exercise: known = union over each transitively-reachable
    concept-exercise's own intro."""
    known = set()
    for cx in transitive_prereq_concept_exes(prereqs):
        known |= known_words_for_concept_ex(cx)
    defined, locals_, used, text = parse_solution(solution_files(exercise_dir, 'practice'))
    unknowns = sorted(used - known - defined - locals_)
    return unknowns + syntax_violations(text, reachable_concepts(prereqs))


def main():
    args = sys.argv[1:]
    if not args:
        kinds = ('concept', 'practice')
    elif args[0] in ('concept', 'practice'):
        kinds = (args[0],)
    else:
        sys.exit(f'Usage: {sys.argv[0]} [concept|practice]')

    issues = 0
    if 'concept' in kinds:
        print('=== concept exercises ===')
        any_concept = False
        for ex in CFG['exercises']['concept']:
            slug = ex['slug']
            ex_dir = ROOT / 'exercises' / 'concept' / slug
            if not (ex_dir / '.meta' / 'config.json').exists():
                continue
            unknowns = check_concept(slug, ex_dir)
            if unknowns:
                any_concept = True
                issues += 1
                print(f'{slug}: {unknowns}')
        if not any_concept:
            print('(none)')

    if 'practice' in kinds:
        print('=== practice exercises ===')
        any_practice = False
        for ex in CFG['exercises'].get('practice', []):
            slug = ex['slug']
            # Deprecated exercises can't carry prerequisites (configlet
            # rejects it), so they will always trip detect-unknown-words.
            # Skip them.
            if ex.get('status') == 'deprecated':
                continue
            ex_dir = ROOT / 'exercises' / 'practice' / slug
            if not (ex_dir / '.meta' / 'config.json').exists():
                continue
            unknowns = check_practice(ex.get('prerequisites', []), ex_dir)
            if unknowns:
                any_practice = True
                issues += 1
                print(f'{slug}: {unknowns}')
        if not any_practice:
            print('(none)')

    sys.exit(1 if issues else 0)


if __name__ == '__main__':
    main()
