USING: kernel ;
IN: triangle

! Declare a `triangle` tuple with slots a, b, and c.

: <triangle> ( a b c -- triangle )
    "unimplemented" throw ;

: equilateral? ( triangle -- ? )
    "unimplemented" throw ;

: isosceles? ( triangle -- ? )
    "unimplemented" throw ;

: scalene? ( triangle -- ? )
    "unimplemented" throw ;
