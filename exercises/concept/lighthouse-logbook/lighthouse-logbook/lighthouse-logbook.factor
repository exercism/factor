USING: kernel ;
IN: lighthouse-logbook

: empty-log ( -- log )
    "unimplemented" throw ;

: sight ( log callsign -- )
    "unimplemented" throw ;

: seen? ( log callsign -- ? )
    "unimplemented" throw ;

: forget-sighting ( log callsign -- )
    "unimplemented" throw ;

: unique-count ( log -- n )
    "unimplemented" throw ;

: reachable ( start relay-map -- visited )
    "unimplemented" throw ;
